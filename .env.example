# DeadlineIQ Environment Variables Template
# Copy this file to '.env' and fill in your credentials to compile them into the build.

# 🧠 Google Gemini API Key (get yours from Google AI Studio: https://aistudio.google.com/)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ⚡ Groq API Key (primary AI engine for task parsing, chat, scheduling, and analysis)
VITE_GROQ_API_KEY=your_groq_api_key_here

# 🔥 Firebase Project Configuration (Optional: replace only if you want to use your own Firebase database)
# VITE_FIREBASE_API_KEY=your_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your_project_id
# VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
# VITE_FIREBASE_APP_ID=your_app_id
